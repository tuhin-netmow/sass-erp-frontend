  Production: ProductionPermission,
  RouteOperations: RouteOperationPermission,
  Help: HelpPermission,
  Payroll: PayrollPermission,
  System: SystemPermission,
} as const;

// Permission labels for UI display - Automated from the keys above
export const PERMISSION_LABELS: Record<string, string> = {
  [DashboardPermission.VIEW]: "View Dashboard",
  [DashboardPermission.STATS]: "View Stats",
  [DashboardPermission.GRAPH]: "View Graph",
  [DashboardPermission.RECENT_SALES_LIST]: "Recent Sales",
  [DashboardPermission.RECENT_CUSTOMERS_LIST]: "Recent Customers",
  [DashboardPermission.PENDING_SALES_LIST]: "Pending Sales",
  [DashboardPermission.CONFIRMED_SALES_LIST]: "Confirmed Sales",
  [DashboardPermission.DELIVERED_SALES_LIST]: "Delivered Sales",
  [DashboardPermission.INTRANSIT_SALES_LIST]: "In-Transit Sales",
  [DashboardPermission.RECENT_ACTIVE_CUSTOMERS_LIST]: "Active Customers",
  [DashboardPermission.RECENT_INACTIVE_CUSTOMERS_LIST]: "Inactive Customers",
  [ProductPermission.VIEW]: "View Products",
  [ProductPermission.LIST]: "List Products",
  [ProductPermission.CREATE]: "Create Products",
  [ProductPermission.EDIT]: "Edit Products",
  [ProductPermission.DELETE]: "Delete Products",
  [CustomerPermission.VIEW]: "View Customers",
  [CustomerPermission.CREATE]: "Create Customers",
  [CustomerPermission.EDIT]: "Edit Customers",
  [CustomerPermission.DELETE]: "Delete Customers",
  [StaffPermission.VIEW]: "View Staffs",
  [StaffPermission.CREATE]: "Create Staffs",
  [StaffPermission.EDIT]: "Edit Staffs",
  [StaffPermission.DELETE]: "Delete Staffs",
  [SalesPermission.VIEW]: "View Sales",
  [SalesPermission.CREATE_ORDER]: "Create Orders",
  [SalesPermission.EDIT_ORDER]: "Edit Orders",
  "*": "All Permissions (Super Admin)",
};

// Helper: Generate available permissions array for UI components
export const generateAvailablePermissions = () => {
  const permissions: Array<{ value: string; label: string; category: string }> = [];

  Object.entries(PERMISSION_GROUPS).forEach(([category, permGroup]) => {
    Object.values(permGroup).forEach((permValue) => {
      const label = PERMISSION_LABELS[permValue as string] || permValue.toString().split('.').slice(0, -1).join(' ').toUpperCase();
      permissions.push({
        value: permValue as string,
        label: label.charAt(0).toUpperCase() + label.slice(1).toLowerCase(),
        category,
      });
    });
  });

  permissions.push({
    value: SuperAdminPermission.ACCESS_ALL,
    label: "Super Admin (Full Access)",
    category: "System",
  });

  return permissions;
};

// --- Type Definitions ---
export type TPermission = {
  module: string;
  actions: string[];
};

export type TPermissions = string[] | TPermission[];
export type PermissionType = string;
